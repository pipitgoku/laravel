{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "barryvdh/laravel-dompdf": "^3.1.1",
        "doctrine/dbal": "^3.8.5",
        "guzzlehttp/guzzle": "^7.8.0",
        "illuminate/mail": "^12.0",
        "laravel/framework": "^12.0",
        "laravel/legacy-factories": "^1.4.1",
        "laravel/sanctum": "^4.0.8",
        "laravel/tinker": "^2.10.1",
        "laravel/ui": "^4.6.1",
        "maatwebsite/excel": "^3.1.63",
        "nwidart/laravel-modules": "^12.0.4",
        "orangehill/iseed": "^3.1.1",
        "phpoffice/phpspreadsheet": "^1.18",
        "predis/predis": "^3.2.0",
        "ramsey/uuid": "^4.9.0",
        "spatie/laravel-activitylog": "^4.10.1",
        "symfony/mailer": "^7.2",
		"symfony/mime": "^7.2",
		"symfony/process": "^7.2",
        "twbs/bootstrap-icons": "^1.13.1",
        "tymon/jwt-auth": "^2.2.0",
        "yajra/laravel-datatables-oracle": "^12.0.0"
    },
    "require-dev": {
		"beyondcode/laravel-dump-server": "^2.1.0",
		"filp/whoops": "^2.18.4",
		"fakerphp/faker": "^1.23",
		"mockery/mockery": "^1.6",
		"nunomaduro/collision": "^8.6",
		"spatie/laravel-ignition": "^2.9.1",
		"phpunit/phpunit": "^11.5.3",
		"laravel/pint": "^1.24.0",
		"laravel/sail": "^1.41.0"
	},
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "wikimedia/composer-merge-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Modules\\": "Modules/",
			"Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "classmap": [
            "database/seeds",
            "database/factories"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    }
}
